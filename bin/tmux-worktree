#!/usr/bin/env bash
set -euo pipefail

# Resolve symlinks so we can find libexec/ relative to the real script
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
BIN_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
PROJECT_ROOT="$(cd "$BIN_DIR/.." && pwd)"
LIBEXEC="$PROJECT_ROOT/libexec"
SHARE="$PROJECT_ROOT/share"
export LIBEXEC SHARE

CONFIG_FILE="${TMUX_WORKTREE_CONFIG:-$HOME/.config/tmux-worktree/config.sh}"
_tw_dir_source=default
[ -n "${TMUX_WORKTREE_DIR:-}" ] && _tw_dir_source=env

_tw_config_loaded=false
if [ -f "$CONFIG_FILE" ]; then
  # shellcheck disable=SC1090
  source "$CONFIG_FILE"
  _tw_config_loaded=true
  # If config set the dir and env didn't, attribute it to config
  [ "$_tw_dir_source" = default ] && [ -n "${TMUX_WORKTREE_DIR:-}" ] && _tw_dir_source=config
fi

TMUX_WORKTREE_DIR="${TMUX_WORKTREE_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/tmux-worktree}"
export TMUX_WORKTREE_DIR

# Default hooks. Users override by defining these in their config.
_tw_user_on_session_create=false
_tw_user_on_worktree_create=false
declare -F on_session_create >/dev/null && _tw_user_on_session_create=true
declare -F on_worktree_create >/dev/null && _tw_user_on_worktree_create=true

if ! $_tw_user_on_session_create; then
  on_session_create() {
    local session="$1" path="$2"
    tmux new-session -d -s "$session" -c "$path"
  }
fi
$_tw_user_on_worktree_create || on_worktree_create() { :; }

# shellcheck source=libexec/cmd-create.sh
source "$LIBEXEC/cmd-create.sh"
# shellcheck source=libexec/cmd-reset.sh
source "$LIBEXEC/cmd-reset.sh"
# shellcheck source=libexec/cmd-shared.sh
source "$LIBEXEC/cmd-shared.sh"

usage() {
  local session_status worktree_status config_status
  if $_tw_user_on_session_create; then session_status="user-defined"; else session_status="default (1 window, 1 pane)"; fi
  if $_tw_user_on_worktree_create; then worktree_status="user-defined"; else worktree_status="default (no-op)"; fi
  if $_tw_config_loaded; then config_status="loaded"; else config_status="not found"; fi

  cat <<EOF
Usage: tmux-worktree <command> [args]

Manage tmux sessions backed by git worktrees.

Commands:
  create <url> <name>   Create a git worktree from the repo url, start tmux session
  reset  [window]       Reset tmux panes in current window and fast-forward branch
  shared <subcommand>   Manage shared-files mechanism (see 'shared help')
  update-self           Pull the latest version of tmux-worktree from origin
  help                  Show this help

Example — two worktrees on the same repo, sharing one bare clone:
  tmux-worktree create git@github.com:org/repo.git feature-1
  tmux-worktree create git@github.com:org/repo.git bugfix-42

  Resulting tree under \$TMUX_WORKTREE_DIR:
    .repo.git/           <- bare clone (shared, created once)
    feature-1/           <- worktree on branch 'feature-1', tmux session 'feature-1'
    bugfix-42/           <- worktree on branch 'bugfix-42', tmux session 'bugfix-42'

Current configuration:
  TMUX_WORKTREE_DIR     $TMUX_WORKTREE_DIR  (from $_tw_dir_source)
  Config file           $CONFIG_FILE  ($config_status)
  on_session_create     $session_status
  on_worktree_create    $worktree_status
EOF
}

cmd_update_self() {
  if ! git -C "$PROJECT_ROOT" rev-parse --git-dir >/dev/null 2>&1; then
    echo "Error: $PROJECT_ROOT is not a git checkout — can't update" >&2
    return 1
  fi
  echo "Updating tmux-worktree in $PROJECT_ROOT"
  git -C "$PROJECT_ROOT" pull --ff-only
}

cmd="${1:-help}"
shift || true
case "$cmd" in
create) cmd_create "$@" ;;
reset) cmd_reset "$@" ;;
shared) cmd_shared "$@" ;;
update-self) cmd_update_self "$@" ;;
help | -h | --help) usage ;;
*)
  echo "Unknown command: $cmd" >&2
  usage >&2
  exit 1
  ;;
esac
