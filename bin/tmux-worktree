#!/usr/bin/env bash
set -euo pipefail

# Resolve symlinks so we can find libexec/ relative to the real script
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
BIN_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
PROJECT_ROOT="$(cd "$BIN_DIR/.." && pwd)"
LIBEXEC="$PROJECT_ROOT/libexec"
SHARE="$PROJECT_ROOT/share"
export LIBEXEC SHARE

CONFIG_FILE="${TMUX_WORKTREE_CONFIG:-$HOME/.config/tmux-worktree/config.sh}"
if [ -f "$CONFIG_FILE" ]; then
  # shellcheck disable=SC1090
  source "$CONFIG_FILE"
fi

TMUX_WORKTREE_DIR="${TMUX_WORKTREE_DIR:-$HOME/code}"
export TMUX_WORKTREE_DIR

# Default hooks. Users override by defining these in their config.
if ! declare -F on_session_create >/dev/null; then
  on_session_create() {
    local session="$1" path="$2"
    tmux new-session -d -s "$session" -c "$path"
  }
fi
declare -F on_worktree_create >/dev/null || on_worktree_create() { :; }

# shellcheck source=libexec/cmd-create.sh
source "$LIBEXEC/cmd-create.sh"
# shellcheck source=libexec/cmd-reset.sh
source "$LIBEXEC/cmd-reset.sh"
# shellcheck source=libexec/cmd-shared.sh
source "$LIBEXEC/cmd-shared.sh"

usage() {
  cat <<EOF
Usage: tmux-worktree <command> [args]

Manage tmux sessions backed by git worktrees.

Commands:
  create <url> <name>   Clone repo (if needed), add worktree, start tmux session
  reset  [window]       Reset panes in current window and fast-forward branch
  shared <subcommand>   Manage shared-files mechanism (see 'shared help')
  help                  Show this help

Environment:
  TMUX_WORKTREE_DIR     Base directory for repos (default: \$HOME/code)
  TMUX_WORKTREE_CONFIG  Config path (default: ~/.config/tmux-worktree/config.sh)

Config hooks (define in config.sh):
  on_session_create <session> <path>   Build tmux layout. Default: 1 window, 1 pane.
  on_worktree_create <path>            Run after worktree is created.
EOF
}

cmd="${1:-help}"
shift || true
case "$cmd" in
  create) cmd_create "$@" ;;
  reset)  cmd_reset  "$@" ;;
  shared) cmd_shared "$@" ;;
  help|-h|--help) usage ;;
  *) echo "Unknown command: $cmd" >&2; usage >&2; exit 1 ;;
esac
